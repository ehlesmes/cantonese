      "content": [
        {
          "type": "title",
          "value": "Specifiers: This and That"
        },
        {
          "type": "text",
          "value": "To point something out, Cantonese uses <strong>呢</strong> (ni1 - this) and <strong>嗰</strong> (go2 - that). Just like numbers, these specifiers <strong>must</strong> be followed by a classifier."
        },
        {
          "type": "example",
          "cantonese": "呢個",
          "romanization": "ni1 go3",
          "translation": "This one"
        },
        {
          "type": "example",
          "cantonese": "嗰個",
          "romanization": "go2 go3",
          "translation": "That one"
        },
        {
          "type": "example",
          "cantonese": "呢個人",
          "romanization": "ni1 go3 jan4",
          "translation": "This person"
        },
        {
          "type": "example",
          "cantonese": "嗰個學生",
          "romanization": "go2 go3 hok6 saang1",
          "translation": "That student"
        }
      ]
    },
    {
      "type": "reading",
      "exerciseId": "4.3.2"
    },
    {
      "type": "unscramble",
      "exerciseId": "4.3.3"
    },
    {
      "type": "dialog",
      "lines": [
        {
          "speaker": "A",
          "cantonese": "呢個係唔係阿明呀？",
          "romanization": "ni1 go3 hai6 m4 hai6 aa3 ming4 aa3?",
          "translation": "Is this (person) Ah Ming?"
        },
        {
          "speaker": "B",
          "cantonese": "唔係。嗰個先係。",
          "romanization": "m4 hai6. go2 go3 sin1 hai6.",
          "translation": "No. That one is (the one)."
        },
        {
          "speaker": "A",
          "cantonese": "哦，你好，阿明。",
          "romanization": "o4, nei5 hou2, aa3 ming4.",
          "translation": "Oh, hello, Ah Ming."
        }
      ]
    },
    {
      "type": "congratulations",
      "title": "Specifiers Mastered!",
      "summary": "You can now point out specific people and objects using 'ni1' and 'go2' with classifiers.",
      "nextLessonId": "4.4"
    }
  ]
}
