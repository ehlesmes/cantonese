  "pages": [
    {
      "type": "explanation",
      "content": [
        {
          "type": "title",
          "value": "Question Words with Classifiers"
        },
        {
          "type": "text",
          "value": "When asking 'which' or 'how many' about specific objects or people, you must include a classifier."
        },
        {
          "type": "title",
          "value": "Which one: bin1"
        },
        {
          "type": "text",
          "value": "<strong>邊個</strong> (bin1 go3) means 'which one'. It is also the most common way to say 'who' in Cantonese."
        },
        {
          "type": "example",
          "cantonese": "邊個？",
          "romanization": "bin1 go3?",
          "translation": "Which one? / Who?"
        },
        {
          "type": "title",
          "value": "How many: gei2 do1"
        },
        {
          "type": "text",
          "value": "To ask 'how many', use <strong>幾多</strong> (gei2 do1) followed by the classifier."
        },
        {
          "type": "example",
          "cantonese": "需要",
          "romanization": "seoi1 jiu3",
          "translation": "Need"
        },
        {
          "type": "example",
          "cantonese": "部",
          "romanization": "bou6",
          "translation": "Classifier for machines/computers"
        },
        {
          "type": "example",
          "cantonese": "幾多",
          "romanization": "gei2 do1",
          "translation": "How many"
        },
        {
          "type": "example",
          "cantonese": "部",
          "romanization": "bou6",
          "translation": "Classifier (machines)"
        },
        {
          "type": "example",
          "cantonese": "電腦",
          "romanization": "din6 nou5",
          "translation": "Computer"
        }
      ]
    },
    { "type": "reading", "exerciseId": "4.4.2" },
    { "type": "reading", "exerciseId": "4.4.4" },
    { "type": "reading", "exerciseId": "4.4.6" },
    { "type": "reading", "exerciseId": "4.4.7" },
    { "type": "reading", "exerciseId": "4.4.8" },
    { "type": "unscramble", "exerciseId": "4.4.5" },
    { "type": "unscramble", "exerciseId": "4.4.3" },
    {
      "type": "dialog",
      "lines": [
        {
          "speaker": "A",
          "cantonese": "邊個係先生呀？",
          "romanization": "bin1 go3 hai6 sin1 saang1 aa3?",
          "translation": "Which one is the teacher?"
        },
        {
          "speaker": "B",
          "cantonese": "呢個。",
          "romanization": "ni1 go3.",
          "translation": "This one."
        }
      ]
    },
    {
      "type": "dialog",
      "lines": [
        {
          "speaker": "A",
          "cantonese": "陳經理，貴公司需要幾多部電腦？",
          "romanization": "can4 ging1 lei5, gwai3 gung1 si1 seoi1 jiu3 gei2 do1 bou6 din6 nou5?",
          "translation": "Manager Chan, how many computers does your company need?"
        },
        {
          "speaker": "B",
          "cantonese": "我哋需要五部電腦。",
          "romanization": "ngo5 dei6 seoi1 jiu3 ng5 bou6 din6 nou5.",
          "translation": "We need five computers."
        }
      ]
    },
    {
      "type": "dialog",
      "lines": [
        {
          "speaker": "A",
          "cantonese": "你哋幾多個人呀？",
          "romanization": "nei5 dei6 gei2 do1 go3 jan4 aa3?",
          "translation": "How many people are you?"
        },
        {
          "speaker": "B",
          "cantonese": "我哋兩個。",
          "romanization": "ngo5 dei6 loeng5 go3.",
          "translation": "We are two (people)."
        }
      ]
    },
