        {
          "type": "title",
          "value": "Pronouns"
        },
        {
          "type": "text",
          "value": "Let's learn how to refer to people."
        },
        {
          "type": "example",
          "cantonese": "我",
          "romanization": "ngo5",
          "translation": "I / Me"
        },
        {
          "type": "example",
          "cantonese": "你",
          "romanization": "nei5",
          "translation": "You"
        },
        {
          "type": "example",
          "cantonese": "佢",
          "romanization": "keoi5",
          "translation": "He / She / It"
        }
      ]
    },
    {
      "type": "dialog",
      "pageId": "1.2.1b",
      "lines": [
        {
          "speaker": "A",
          "cantonese": "你好嗎？",
          "romanization": "nei5 hou2 maa3?",
          "translation": "How are you?"
        },
        {
          "speaker": "B",
          "cantonese": "我好，你呢？",
          "romanization": "ngo5 hou2, nei5 ne1?",
          "translation": "I'm good, and you?"
        },
        {
          "speaker": "A",
          "cantonese": "佢呢？",
          "romanization": "keoi5 ne1?",
          "translation": "And him?"
        },
        {
          "speaker": "B",
          "cantonese": "佢都好。",
          "romanization": "keoi5 dou1 hou2.",
          "translation": "He is also good."
        }
      ]
    },
