      "type": "explanation",
      "content": [
        {
          "type": "title",
          "value": "Ending Consonants"
        },
        {
          "type": "text",
          "value": "Cantonese syllables can end in continuous nasal sounds or abrupt stop sounds."
        },
        {
          "type": "title",
          "value": "Nasal Endings (-m, -n, -ng)"
        },
        {
          "type": "example",
          "cantonese": "三",
          "romanization": "saam1",
          "translation": "Three (-m ending)"
        },
        {
          "type": "example",
          "cantonese": "新",
          "romanization": "san1",
          "translation": "New (-n ending)"
        },
        {
          "type": "example",
          "cantonese": "生",
          "romanization": "sang1",
          "translation": "Birth (-ng ending)"
        }
      ]
    },
    {
      "type": "explanation",
      "content": [
        {
          "type": "title",
          "value": "Stop Endings (-p, -t, -k)"
        },
        {
          "type": "text",
          "value": "These sounds are cut off suddenly. You don't actually 'release' the air like in English 'top'."
        },
        {
          "type": "example",
          "cantonese": "霎",
          "romanization": "saap3",
          "translation": "Suddenly (-p ending)"
        },
        {
          "type": "example",
          "cantonese": "殺",
          "romanization": "saat3",
          "translation": "Kill (-t ending)"
        },
        {
          "type": "example",
          "cantonese": "索",
          "romanization": "saak3",
          "translation": "Rope (-k ending)"
        }
      ]
    },
