      "content": [
        {
          "type": "title",
          "value": "Counting Objects"
        },
        {
          "type": "text",
          "value": "In Cantonese, we use 'classifiers' between a number and a noun. The most common one is <strong>個</strong> (go3)."
        },
        {
          "type": "example",
          "cantonese": "三個",
          "romanization": "saam1 go3",
          "translation": "Three (of something)"
        },
        {
          "type": "text",
          "value": "Note: For 'two' when counting, we use <strong>兩</strong> (loeng5) instead of <strong>二</strong> (ji6)."
        },
        {
          "type": "example",
          "cantonese": "兩個",
          "romanization": "loeng5 go3",
          "translation": "Two (of something)"
        }
      ]
    },
