      "type": "explanation",
      "content": [
        {
          "type": "title",
          "value": "When: gei2 si4"
        },
        {
          "type": "text",
          "value": "To ask 'when', use <strong>幾時</strong> (gei2 si4). Here are the two most important time words for daily planning."
        },
        {
          "type": "example",
          "cantonese": "幾時？",
          "romanization": "gei2 si4?",
          "translation": "When?"
        },
        {
          "type": "example",
          "cantonese": "今日",
          "romanization": "gam1 jat6",
          "translation": "Today"
        },
        {
          "type": "example",
          "cantonese": "聽日",
          "romanization": "ting1 jat6",
          "translation": "Tomorrow"
        },
        {
          "type": "text",
          "value": "To say 'then' or 'again' in the sense of 'until next time', use <strong>再</strong> (zoi3)."
        },
        {
          "type": "example",
          "cantonese": "會議",
          "romanization": "wui2 ji5",
          "translation": "Meeting"
        },
        {
          "type": "example",
          "cantonese": "下星期",
          "romanization": "haa6 sing1 kei4",
          "translation": "Next week"
        }
      ]
    },
    { "type": "reading", "exerciseId": "5.2.2" },
    { "type": "reading", "exerciseId": "5.2.5" },
    { "type": "reading", "exerciseId": "5.2.6" },
    { "type": "unscramble", "exerciseId": "5.2.3" },
    { "type": "unscramble", "exerciseId": "5.2.4" },
    {
      "type": "dialog",
      "lines": [
        {
          "speaker": "A",
          "cantonese": "你幾時去公司呀？",
          "romanization": "nei5 gei2 si4 heoi3 gung1 si1 aa3?",
          "translation": "When are you going to the office?"
        },
        {
          "speaker": "B",
          "cantonese": "我今日唔去。我聽日先去。",
          "romanization": "ngo5 gam1 jat6 m4 heoi3. ngo5 ting1 jat6 sin1 heoi3.",
          "translation": "I'm not going today. I'm going tomorrow."
        },
        {
          "speaker": "A",
          "cantonese": "好呀，聽日見。",
          "romanization": "hou2 aa3, ting1 jat6 gin3.",
          "translation": "Okay, see you tomorrow."
        }
      ]
    },
    {
      "type": "dialog",
      "lines": [
        {
          "speaker": "A",
          "cantonese": "陳經理，會議幾時舉行？",
          "romanization": "can4 ging1 lei5, wui2 ji5 gei2 si4 heoi2 hang4?",
          "translation": "Manager Chan, when will the meeting be held?"
        },
        {
          "speaker": "B",
          "cantonese": "會議下星期舉行。",
          "romanization": "wui2 ji5 haa6 sing1 kei4 heoi2 hang4.",
          "translation": "The meeting will be held next week."
        }
      ]
    },
    {
      "type": "congratulations",
      "title": "Time Mastered!",
      "summary": "You can now make plans and ask about the timing of events.",
      "nextLessonId": "5.3"
    }
  ]
