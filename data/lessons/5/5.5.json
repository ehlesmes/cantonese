    { "type": "unscramble", "exerciseId": "5.5.5" },
    {
      "type": "dialog",
      "lines": [
        {
          "speaker": "A",
          "cantonese": "佢哋幾多個人去呀？",
          "romanization": "keoi5 dei6 gei2 do1 go3 jan4 heoi3 aa3?",
          "translation": "How many of them are going?"
        },
        {
          "speaker": "B",
          "cantonese": "三個人咋。",
          "romanization": "saam1 go3 jan4 zaa3.",
          "translation": "Only three people."
        },
        {
          "speaker": "A",
          "cantonese": "係啩。",
          "romanization": "hai6 gwaa3.",
          "translation": "I suppose so."
        }
      ]
    },
    {
      "type": "dialog",
      "lines": [
        {
          "speaker": "A",
          "cantonese": "陳經理，據悉本月業績將會增長。",
          "romanization": "can4 ging1 lei5, geoi3 sik1 bun2 jyut6 jip6 zik1 zoeng1 wui5 zang1 zoeng2.",
          "translation": "Manager Chan, it is understood that the performance this month will increase."
        },
        {
          "speaker": "B",
          "cantonese": "係，確係如此。",
          "romanization": "hai6, kok3 hai6 jyu4 ci2.",
          "translation": "Yes, that is indeed the case."
        }
      ]
    },
