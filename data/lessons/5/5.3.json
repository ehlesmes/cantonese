    {
      "type": "dialog",
      "lines": [
        {
          "speaker": "A",
          "cantonese": "你點樣去公司呀？",
          "romanization": "nei5 dim2 joeng2 heoi3 gung1 si1 aa3?",
          "translation": "How do you go to the office?"
        },
        {
          "speaker": "B",
          "cantonese": "我搭車。你呢？",
          "romanization": "ngo5 daap3 ce1. nei5 ne1?",
          "translation": "I take the bus/car. And you?"
        },
        {
          "speaker": "A",
          "cantonese": "我行路。",
          "romanization": "ngo5 haang4 lou6.",
          "translation": "I walk."
        }
      ]
    },
    {
      "type": "dialog",
      "lines": [
        {
          "speaker": "A",
          "cantonese": "陳經理，請問貴公司同事係點樣去會議嘅？",
          "romanization": "can4 ging1 lei5, ceng2 man6 gwai3 gung1 si1 tung4 si6 hai6 dim2 joeng2 heoi3 wui2 ji5 ge3?",
          "translation": "Manager Chan, may I ask how your company colleagues go to the meeting?"
        },
        {
          "speaker": "B",
          "cantonese": "佢哋搭地鐵去。",
          "romanization": "keoi5 dei6 daap3 dei6 tit3 heoi3.",
          "translation": "They take the subway."
        }
      ]
    },
