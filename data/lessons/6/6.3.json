          "romanization": "nei5 hou2! nei5 hai6 bin1 dou6 jan4 aa3?",
          "translation": "Hello! Where are you from?"
        },
        {
          "speaker": "B",
          "cantonese": "我係美國人。你呢？",
          "romanization": "ngo5 hai6 mei5 gwok3 jan4. nei5 ne1?",
          "translation": "I am American. And you?"
        },
        {
          "speaker": "A",
          "cantonese": "我係英國人。",
          "romanization": "ngo5 hai6 jing1 gwok3 jan4.",
          "translation": "I am British."
        }
      ]
    },
    {
