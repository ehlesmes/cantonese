        {
          "type": "title",
          "value": "Abilities: sik1"
        },
        {
          "type": "text",
          "value": "To express that you know how to do something or that you understand a language, use the verb <strong>識</strong> (sik1). The negative is <strong>唔識</strong> (m4 sik1)."
        },
        {
          "type": "example",
          "cantonese": "識",
          "romanization": "sik1",
          "translation": "To know how to / To understand"
        },
        {
          "type": "example",
          "cantonese": "唔識",
          "romanization": "m4 sik1",
          "translation": "Not know how to / Not understand"
        },
        {
          "type": "example",
          "cantonese": "講",
          "romanization": "gong2",
          "translation": "To speak / To say"
        },
        {
          "type": "title",
          "value": "Languages"
        },
        {
          "type": "example",
          "cantonese": "廣東話",
          "romanization": "gwong2 dung1 waa2",
          "translation": "Cantonese language"
        },
        {
          "type": "example",
          "cantonese": "英文",
          "romanization": "jing1 man2",
          "translation": "English language"
        }
      ]
    },
