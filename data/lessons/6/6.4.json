      "lines": [
        {
          "speaker": "A",
          "cantonese": "你識唔識講廣東話呀？",
          "romanization": "nei5 sik1 m4 sik1 gong2 gwong2 dung1 waa2 aa3?",
          "translation": "Do you know how to speak Cantonese?"
        },
        {
          "speaker": "B",
          "cantonese": "我識講英文. 廣東話我唔識。",
          "romanization": "ngo5 sik1 gong2 jing1 man2. gwong2 dung1 waa2 ngo5 m4 sik1.",
          "translation": "I know how to speak English. Cantonese I don't know."
        },
        {
          "speaker": "A",
          "cantonese": "哦，唔緊要。",
          "romanization": "o4, m4 gan2 jiu3.",
          "translation": "Oh, no problem (it doesn't matter)."
        }
      ]
    },
    {
      "type": "dialog",
      "lines": [
        {
          "speaker": "A",
          "cantonese": "喂，你識唔識講廣東話？",
          "romanization": "wai2, nei5 sik1 m4 sik1 gong2 gwong2 dung1 waa2?",
          "translation": "Hey, do you speak Cantonese?"
        },
        {
          "speaker": "B",
          "cantonese": "英文就識。廣東話就唔識喇。",
          "romanization": "jing1 man2 zau6 sik1. gwong2 dung1 waa2 zau6 m4 sik1 laa3.",
          "translation": "English, yes. Cantonese, no."
        },
        {
          "speaker": "A",
          "cantonese": "係呀？噉算啦。",
          "romanization": "hai6 aa4? gam2 syun3 laa1.",
          "translation": "Oh really? Never mind then."
        }
