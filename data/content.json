          },
          {
            "term": "見",
            "romanization": "gin3",
            "meaning": "See / Meet"
          },
          {
            "term": "今晚",
            "romanization": "gam1 maan5",
            "meaning": "Tonight"
          },
          {
            "term": "時間",
            "romanization": "si4 gaan3",
            "meaning": "Time"
          }
        ],
        "examples": [
          {
            "text": "我晏晝食飯。",
            "romanization": "ngo5 aan3 zau3 sik6 faan6.",
            "translation": "I eat in the afternoon."
          },
          {
            "text": "聽晚見。",
            "romanization": "teng1 maan5 gin3.",
            "translation": "See you tomorrow night."
          },
          {
            "text": "今晚有時間。",
            "romanization": "gam1 maan5 jau5 si4 gaan3.",
            "translation": "I have time tonight."
          }
        ]
