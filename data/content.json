  {
    "id": "lesson-1",
    "title": "Introduction to Cantonese",
    "pages": [
      {
        "type": "intro",
        "title": "Introduction to Cantonese",
        "goal": "Greeting people and asking for names"
      },
      {
        "type": "learn",
        "title": "Basic Greetings",
        "text": "Cantonese greetings are often informal. Here are some fundamental ways to greet people.",
        "vocabulary": [
          {
            "term": "你好",
            "romanization": "nei5 hou2",
            "meaning": "Hello"
          },
          {
            "term": "早晨",
            "romanization": "zou2 san4",
            "meaning": "Good morning"
          },
          {
            "term": "再見",
            "romanization": "zoi3 gin3",
            "meaning": "Goodbye"
          }
        ],
        "examples": [
          {
            "text": "你好！",
            "romanization": "nei5 hou2!",
            "translation": "Hello!"
          },
          {
            "text": "早晨。",
            "romanization": "zou2 san4.",
            "translation": "Good morning."
          },
          {
            "text": "再見。",
            "romanization": "zoi3 gin3.",
            "translation": "Goodbye."
          }
        ]
      },
      {
        "type": "practice",
        "exerciseType": "reading",
        "text": "你好！",
        "romanization": "nei5 hou2!",
        "translation": "Hello!",
