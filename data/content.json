        "type": "practice",
        "exerciseType": "reading",
        "text": "早晨。",
        "romanization": "zou2 san4.",
        "translation": "Good morning.",
        "audio": "audio/lesson1/5.m4a"
      },
      {
        "type": "practice",
        "exerciseType": "reading",
        "text": "再見。",
        "romanization": "zoi3 gin3.",
        "translation": "Goodbye.",
        "audio": "audio/lesson1/6.m4a"
      },
      {
        "type": "learn",
        "title": "Asking for Names & Identity",
        "text": "Basic sentence structure is Subject-Verb-Object. '你' (nei5) is 'you', '我' (ngo5) is 'I', and '係' (hai6) is 'to be'. The particle '呢' (ne1) is used as a tag question, like 'how about...?'",
        "vocabulary": [
          {
            "term": "你",
            "romanization": "nei5",
            "meaning": "You"
          },
          {
            "term": "我",
            "romanization": "ngo5",
            "meaning": "I"
          },
          {
            "term": "係",
            "romanization": "hai6",
            "meaning": "To be"
          },
          {
            "term": "叫",
            "romanization": "giu3",
            "meaning": "To be called"
          },
          {
            "term": "咩",
            "romanization": "me1",
            "meaning": "What (in questions)"
          },
          {
            "term": "名",
            "romanization": "meng2",
            "meaning": "Name"
          },
          {
            "term": "邊個",
            "romanization": "bin1 go3",
            "meaning": "Who"
          },
          {
            "term": "呢",
            "romanization": "ne1",
            "meaning": "Particle (how about...?)",
            "tag": "particle"
          },
          {
            "term": "學生",
            "romanization": "hok6 saang1",
            "meaning": "Student"
          }
        ],
        "examples": [
          {
            "text": "我叫小明。",
            "romanization": "ngo5 giu3 siu2 ming4.",
            "translation": "My name is Siu Ming."
          },
          {
            "text": "你叫咩名？",
            "romanization": "nei5 giu3 me1 meng2?",
            "translation": "What is your name?"
          },
          {
            "text": "你係邊個？",
            "romanization": "nei5 hai6 bin1 go3?",
            "translation": "Who are you?"
          },
          {
            "text": "我係學生。",
            "romanization": "ngo5 hai6 hok6 saang1.",
            "translation": "I am a student."
          },
          {
            "text": "你呢？",
            "romanization": "nei5 ne1?",
            "translation": "How about you?"
          },
          {
            "text": "你好，我係David。",
            "romanization": "nei5 hou2, ngo5 hai6 David.",
            "translation": "Hello, I am David."
          }
        ]
      },
