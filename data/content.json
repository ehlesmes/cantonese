        "goal": "Shopping and ordering food"
      },
      {
        "type": "learn",
        "title": "Ordering Food & Drinks",
        "text": "Using '我要' (ngo5 jiu3) for 'I want'. Cantonese uses classifiers (like '個' - go3 for items, or '杯' - bui1 for cups) before nouns, especially after numbers.",
        "vocabulary": [
          {
            "term": "我要",
            "romanization": "ngo5 jiu3",
            "meaning": "I want"
          },
          {
            "term": "我唔要",
            "romanization": "ngo5 m4 jiu3",
            "meaning": "I don't want"
          },
          {
            "term": "個",
            "romanization": "go3",
            "meaning": "Classifier (general)"
          },
          {
            "term": "一杯",
            "romanization": "jat1 bui1",
            "meaning": "One cup of"
          },
          {
            "term": "菠蘿包",
            "romanization": "bo1 lo4 baau1",
            "meaning": "Pineapple bun"
          },
          {
            "term": "奶茶",
            "romanization": "naai5 caa4",
            "meaning": "Milk tea"
          },
          {
            "term": "水",
            "romanization": "seoi2",
            "meaning": "Water"
          },
          {
            "term": "有冇",
            "romanization": "jau5 mou5",
            "meaning": "Do you have?"
          }
        ],
        "examples": [
          {
            "text": "我要一個菠蘿包。",
            "romanization": "ngo5 jiu3 jat1 go3 bo1 lo4 baau1.",
            "translation": "I want a pineapple bun."
          },
          {
            "text": "我要一杯奶茶。",
            "romanization": "ngo5 jiu3 jat1 bui1 naai5 caa4.",
            "translation": "I want a cup of milk tea."
          },
          {
            "text": "有冇水？",
            "romanization": "jau5 mou5 seoi2?",
            "translation": "Do you have water?"
          },
          {
            "text": "我唔要。",
            "romanization": "ngo5 m4 jiu3.",
            "translation": "I don't want (it)."
          }
        ]
      },
